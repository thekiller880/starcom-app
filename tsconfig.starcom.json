  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "src/testing/**/*",
    "src/**/__tests__/**/*",
    "src/**/tests/**/*",
    "src/examples/**/*",
    "src/core/intel/examples/**/*",
    "src/core/intel/tests/**/*",
    "src/core/intel/**/*",
    "src/applications/netrunner/**/*",
