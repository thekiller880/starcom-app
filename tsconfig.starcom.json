{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "incremental": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.starcom.tsbuildinfo"
  },
  "include": [
    "src/main.tsx",
    "src/main.ts",
    "src/index.tsx",
    "src/App.tsx",
    "src/layouts/**/*",
    "src/hooks/**/*",
    "src/services/**/*",
    "src/utils/**/*",
    "src/models/**/*",
    "src/components/HUD/**/*",
    "src/components/NotificationSystem/**/*",
    "src/components/Popup/**/*",
    "src/components/Bridge/**/*",
    "src/components/Adaptive/**/*",
    "src/components/Optimization/**/*",
    "src/components/Gaming/**/*"
